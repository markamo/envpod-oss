[28.96, "o", "\r\u001b[0;32m$ \u001b[0m\u001b[38;5;15msudo\u001b[39m\u001b[38;5;15m \u001b[39m\u001b[38;5;15menvpod\u001b[39m\u001b[38;5;15m \u001b[39m\u001b[38;5;15mrun\u001b[39m\u001b[38;5;15m \u001b[39m\u001b[38;5;15mhello\u001b[39m\u001b[38;5;15m \u001b[39m\u001b[38;5;15m--\u001b[39m\u001b[38;5;15m \u001b[39m\u001b[38;5;15mbash\u001b[39m\u001b[38;5;15m \u001b[39m\u001b[38;5;15m-c\u001b[39m\u001b[38;5;15m \u001b[39m\u001b[38;5;186m\"echo 'the agent wrote this' > /home/agent/hello.txt && echo 'wrote /home/agent/hello.txt inside pod'\"\u001b[39m\u001b[0m"]
[29.76, "o", "\r\n"]
[29.76, "o", "\u001b[0mwrote /home/agent/hello.txt inside pod\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m  \u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m  \u2502 envpod v0.1.0 \u2014 Zero-trust governance for AI agents \u2502\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m  \u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m  This pod is governed. Every action is:\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m    \u00b7 Isolated    \u2014 writes go to a COW overlay, never the host\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m    \u00b7 Auditable   \u2014 all actions logged to the audit trail\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m    \u00b7 Reversible  \u2014 review changes with diff, commit or rollback\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m    \u00b7 Restricted \u2014 network filtered, resources capped\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m  Commands: envpod diff | commit | rollback | audit\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m  \u00a9 2026 Mark Amo-Boateng / Xtellix Inc. \u2014 Apache-2.0 License\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m  https://envpod.com\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m  envpod \u00b7 hello\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m  Type      standard\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m  Network   monitored \u00b7 dns monitor\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m  FS        system advanced\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m  CPU       2 cores \u00b7 4GB\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m  GPU       denied\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m  Budget    8h\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m\u001b[0m\r\n"]
[29.76, "o", "\u001b[0m  Command   bash -c echo 'the agent wrote this' > /home/agent/hello.txt && echo 'wrote /home/agent/hello.txt inside pod'\u001b[0m\r\n"]
