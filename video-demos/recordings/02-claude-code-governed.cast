[52.914118, "o", "\r\n  \u001b[1menvpod security audit\u001b[0m \u001b[2m· claude-code\u001b[0m\r\n\r\n  \u001b[2mPod boundary\u001b[0m  \u001b[32m17\u001b[0m/17 with default user\r\n\r\n  \u001b[33m⚠\u001b[0m 2 security notes:\r\n\r\n  \u001b[1mS-03\u001b[0m  \u001b[31m[HIGH]\u001b[0m Relaxed seccomp profile\r\n        \u001b[2mseccomp_profile is browser — allows clone3, unshare, and other syscalls blocked by default.\u001b[0m\r\n        Fix: remove security.seccomp_profile or set to default if browser features are not needed.\r\n\r\n  \u001b[1mP-03\u001b[0m  \u001b[33m[MEDIUM]\u001b[0m Nested namespaces possible\r\n        \u001b[2mseccomp_profile is browser — unshare/clone3 allow nested namespace creation.\u001b[0m\r\n        Fix: remove security.seccomp_profile or set to default if browser features are not needed.\r\n\r\n  \u001b[32m✓\u001b[0m 8 checks passed (user, dns, memory, cpu, pids, ...)\r\n\r\n"]
