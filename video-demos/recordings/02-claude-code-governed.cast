[0.027854, "o", "\u001b[1m\u001b[0;36m  ║\u001b[0m\u001b[1m   Claude Code — Governed                         \u001b[0;36m║\u001b[0m\r\n\u001b[1m\u001b[0;36m  ║\u001b[0m\u001b[2m   AI coding agent with full isolation            \u001b[0;36m║\u001b[0m\r\n\u001b[1m\u001b[0;36m  ║                                                  ║\u001b[0m\r\n"]
[0.027887, "o", "\u001b[1m\u001b[0;36m  ╚══════════════════════════════════════════════════╝\u001b[0m\r\n\r\n\r\n"]
[3.030143, "o", "\r\n\u001b[2m# Claude Code has full access to your filesystem, API keys, git credentials. Let's fix that.\u001b[0m\r\n"]
