[69.893006, "o", "  \u001b[36m└─────────────────────────────────────────────────────┘\u001b[0m\r\n\r\n  This pod is \u001b[1mgoverned\u001b[0m. Every action is:\r\n    \u001b[32m·\u001b[0m \u001b[1mIsolated\u001b[0m    — writes go to a COW overlay, never the host\r\n    \u001b[32m·\u001b[0m \u001b[1mAuditable\u001b[0m   — all actions logged to the audit trail\r\n    \u001b[32m·\u001b[0m \u001b[1mReversible\u001b[0m  — review changes with diff, commit or rollback\r\n    \u001b[32m·\u001b[0m \u001b[1mRestricted\u001b[0m — network filtered, resources capped\r\n\r\n  Commands: \u001b[36menvpod diff\u001b[0m | \u001b[36mcommit\u001b[0m | \u001b[36mrollback\u001b[0m | \u001b[36maudit\u001b[0m\r\n\r\n  \u001b[2m© 2026 Mark Amo-Boateng / Xtellix Inc. — Apache-2.0 License\u001b[0m\r\n  \u001b[2mhttps://envpod.com\u001b[0m\r\n\r\n"]
[69.893089, "o", "\r\n  \u001b[1menvpod\u001b[0m \u001b[2m·\u001b[0m \u001b[36mclaude-code-2\u001b[0m\r\n  \u001b[2mType    \u001b[0m  standard\r\n  \u001b[2mNetwork \u001b[0m  monitored \u001b[2m·\u001b[0m dns whitelist\r\n  \u001b[2mFS      \u001b[0m  system safe"]
[69.893114, "o", " \u001b[2m·\u001b[0m 1 setup steps\r\n  \u001b[2mCPU     \u001b[0m  2 cores \u001b[2m·\u001b[0m "]
[69.893247, "o", "4GB\r\n  \u001b[2mGPU     \u001b[0m  denied\r\n  \u001b[2mBudget  \u001b[0m  30m\r\n\r\n  \u001b[2mCommand \u001b[0m  echo I am a separate, independent pod\r\n  \u001b[2mUser    \u001b[0m  agent\r\n\r\n"]
