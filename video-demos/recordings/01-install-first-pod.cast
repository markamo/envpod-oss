[18.270497, "o", "\r\n  \u001b[1m┌─────────────────────────────────────────────────────┐\u001b[0m\r\n  \u001b[1m│ envpod v0.1.0 — Zero-trust governance for AI agents │\u001b[0m\r\n  \u001b[1m└─────────────────────────────────────────────────────┘\u001b[0m\r\n\r\n"]
[19.29547, "o", "\u001b[2m  ────────────────────────────────────────\u001b[0m\r\n  \u001b[1mPod Created\u001b[0m \u001b[2m·\u001b[0m \u001b[36mhello\u001b[0m  \u001b[2m1.0s\u001b[0m\r\n\u001b[2m  ────────────────────────────────────────\u001b[0m\r\n\r\n  \u001b[2mBackend\u001b[0m  native\r\n  \u001b[2mNetwork\u001b[0m  monitored \u001b[2m·\u001b[0m dns monitor\r\n  \u001b[2mFS     \u001b[0m  system advanced\r\n  \u001b[2mCPU    \u001b[0m  2 cores \u001b[2m·\u001b[0m 4GB\r\n  \u001b[2mBudget \u001b[0m  8h\r\n\r\n"]
[19.655738, "o", "\r\n\u001b[2m  ────────────────────────────────────────\u001b[0m\r\n  \u001b[32mReady\u001b[0m  \u001b[2m1.4s\u001b[0m\r\n\u001b[2m  ────────────────────────────────────────\u001b[0m\r\n\r\n  \u001b[2mRun\u001b[0m  sudo envpod run hello -- bash\r\n  \u001b[2mSecurity\u001b[0m 2 notes — run: sudo envpod audit hello --security\r\n\r\n"]
