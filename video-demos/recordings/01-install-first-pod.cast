[10.634587, "o", "  \u001b[1mCoding Agents\u001b[0m\r\n    1  claude-code     Anthropic Claude Code CLI\r\n    2  codex           OpenAI Codex CLI\r\n    3  gemini-cli      Google Gemini CLI\r\n    4  opencode        OpenCode terminal agent\r\n    5  aider           Aider AI pair programmer\r\n    6  swe-agent       SWE-agent autonomous coder\r\n\r\n  \u001b[1mFrameworks\u001b[0m\r\n    7  langgraph       LangGraph workflows\r\n    8  google-adk      Google Agent Development Kit\r\n    9  openclaw        OpenClaw messaging assistant\r\n\r\n  \u001b[1mBrowser Agents\u001b[0m\r\n   10  browser-use     Browser-use web automation\r\n   11  playwright      Playwright browser automation\r\n   12  browser         Headless Chrome sandbox\r\n\r\n  \u001b[1mEnvironments\u001b[0m\r\n   13  devbox          General dev sandbox\r\n   14  python-env      Python environment\r\n   15  nodejs          Node.js environment\r\n   16  web-display     noVNC desktop\r\n   17  desktop         XFCE desktop via noVNC\r\n   18  vscode          VS Code in the browser\r\n"]
