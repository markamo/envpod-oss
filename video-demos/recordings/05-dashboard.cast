[18.8, "o", "\r\n"]
[18.8, "o", "  \u001b[2m# Narration: \"Four agents, four presets, four commands. Each one fully isolated and governed.\"\u001b[0m\r\n"]
[19.9, "o", "\r\n"]
[19.9, "o", "\r\n"]
[19.9, "o", "  \u001b[2m# [0:15] Start the dashboard:\u001b[0m\r\n"]
[21.0, "o", "\r\n"]
[21.0, "o", "\u001b[0;32m$ \u001b[0m"]
[21.0, "o", "\u001b[0m"]
[21.0, "o", "s"]
[21.03, "o", "u"]
