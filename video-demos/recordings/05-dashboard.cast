[21.63, "o", "\u001b[0m"]
[21.63, "o", "\r\u001b[0;32m$ \u001b[0m\u001b[38;5;15msudo\u001b[39m\u001b[38;5;15m \u001b[39m\u001b[38;5;15menvpod\u001b[39m\u001b[38;5;15m \u001b[39m\u001b[38;5;15mdashboard\u001b[39m\u001b[0m"]
[22.43, "o", "\r\n"]
[23.93, "o", "\r\n"]
[23.93, "o", "  \u001b[2m# Browser opens to localhost:9090.\u001b[0m\r\n"]
[25.03, "o", "\r\n"]
[25.03, "o", "\r\n"]
[25.03, "o", "  \u001b[2m# [0:22] Fleet overview \u2014 show pod cards with status, CPU/memory, diff counts.\u001b[0m\r\n"]
[26.13, "o", "\r\n"]
[26.13, "o", "\r\n"]
[26.13, "o", "  \u001b[2m# Narration: \"Every pod at a glance. Status, resource consumption, how many files changed.\"\u001b[0m\r\n"]
[27.23, "o", "\r\n"]
[27.23, "o", "\r\n"]
[27.23, "o", "  \u001b[2m# [0:35] Click into a pod (e.g. claude-code). Show tabs: - Overview: config summary, vault key names\u001b[0m\r\n"]
[27.23, "o", "  \u001b[2m# (not values) - Audit: scrollable timeline of every action - Diff: file list, colored by change type\u001b[0m\r\n"]
[27.23, "o", "  \u001b[2m# - Resources: live CPU, memory, PID counts - Snapshots: checkpoint history with create/restore/delete\u001b[0m\r\n"]
[28.93, "o", "\r\n"]
[28.93, "o", "\r\n"]
[28.93, "o", "  \u001b[2m# [0:55] Click \"Diff\" tab. Review changes. Click \"Commit\" from the browser.\u001b[0m\r\n"]
[30.03, "o", "\r\n"]
[30.03, "o", "\r\n"]
[30.03, "o", "  \u001b[2m# Narration: \"Review and commit from the browser. No CLI needed.\"\u001b[0m\r\n"]
[31.13, "o", "\r\n"]
[31.13, "o", "\r\n"]
[31.13, "o", "  \u001b[2m# [1:05] Show snapshots \u2014 create one from the dashboard:\u001b[0m\r\n"]
[32.23, "o", "\r\n"]
[32.23, "o", "\u001b[0mClick \"Create Snapshot\" \u2192 name it \"checkpoint-1\" \u2192 shows in timeline\u001b[0m\r\n"]
[35.73, "o", "\r\n"]
[35.73, "o", "  \u001b[2m# Narration: \"Snapshot the overlay state. Restore any time if something goes wrong.\"\u001b[0m\r\n"]
[36.83, "o", "\r\n"]
[36.83, "o", "\r\n"]
[36.83, "o", "  \u001b[2m# [1:15] Go back to fleet view. Click \"Freeze\" on a pod. Show it freeze instantly.\u001b[0m\r\n"]
[37.93, "o", "\r\n"]
[37.93, "o", "\r\n"]
[37.93, "o", "  \u001b[2m# Narration: \"One click. Every process in the pod suspended.\"\u001b[0m\r\n"]
[39.03, "o", "\r\n"]
[39.03, "o", "\r\n"]
[39.03, "o", "  \u001b[2m# [1:25] End card. Narration: \"18 presets. One dashboard. Full governance.\"\u001b[0m\r\n"]
