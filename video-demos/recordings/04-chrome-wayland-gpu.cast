[20.654934, "o", "# Browser pod (Wayland + PipeWire) — secure display and audio for web agents\r\n#\r\n# Same as browser.yaml but uses Wayland for display (eliminates X11 keylogging)\r\n# and PipeWire for audio (finer-grained permissions vs PulseAudio).\r\n#\r\n# Security improvements over browser.yaml:\r\n#   I-04: CRITICAL → LOW  (Wayland compositor isolates clients)\r\n#   I-05: HIGH → MEDIUM   (PipeWire has per-stream permissions)\r\n#\r\n# Requires: Wayland compositor on host (GNOME/KDE on Wayland, sway, etc.)\r\n#           PipeWire running on host (default on Ubuntu 22.10+, Fedora 34+)\r\n#\r\n# Display: use --enable-display (-d) for Wayland forwarding.\r\n#          Socket mounted to /tmp/wayland-0 inside pod.\r\n# Audio:   use --enable-audio (-a) for PipeWire forwarding.\r\n#          Socket mounted to /tmp/pipewire-0 inside pod.\r\n#\r\n# Note: Firefox is a snap on Ubuntu 24.04 and does not work inside namespace\r\n#       pods. Use Google Chrome (deb package) instead.\r\n#\r\n# Chrome flags:\r\n#   --ozone-platform=wayland  Required for Chrome to use Wayland (defaults to X11)\r\n#   --no-sandbox              Safe here — the pod already provides isolation\r\n#\r\n# Usage:\r\n#   sudo envpod init browser-wayland -c examples/browser-wayland.yaml\r\n#   sudo envpod run browser-wayland -d -a -- google-chrome --no-sandbox --ozone-platform=wayland https://example.com\r\n#   sudo envpod audit browser-wayland --security\r\n\r\nname: browser-wayland\r\ntype: standard\r\nbackend: native\r\n\r\nnetwork:\r\n  mode: Monitored\r\n  dns:\r\n    mode: Blacklist\r\n    deny:\r\n      - \"*.internal\"\r\n      - \"*.local\"\r\n      - \"*.corp\"\r\n\r\nfilesystem:\r\n  mounts:\r\n    - path: /opt/google\r\n      permissions: ReadOnly\r\n    - path: /etc/alternatives\r\n      permissions: ReadOnly\r\n  tracking:\r\n    watch:\r\n      - /home\r\n      - /opt\r\n      - /root\r\n      - /workspace\r\n    ignore:\r\n      - /var/cache\r\n      - /var/lib/apt\r\n      - /var/lib/dpkg\r\n      - /tmp\r\n      - /run\r\n\r\nprocessor:\r\n  cores: 2.0\r\n  memory: \"4GB\"\r\n  max_pids: 1024\r\n\r\nsecurity:\r\n  seccomp_profile: browser\r\n  shm_size: \"256MB\"\r\n\r\ndevices:\r\n  gpu: true\r\n  display: true\r\n  audio: true\r\n  display_protocol: wayland\r\n  audio_protocol: pipewire\r\n\r\nbudget:\r\n  max_duration: \"30m\"\r\n\r\naudit:\r\n  action_log: true\r\n"]
[22.657408, "o", "\r\n\u001b[2m# GPU, Wayland display, PipeWire audio, browser seccomp, 4GB RAM.\u001b[0m\r\n"]
[25.659836, "o", "\r\n\r\n"]
