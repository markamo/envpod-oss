[57.103785, "o", "\r\n"]
[57.112037, "o", "\r\n  \u001b[1menvpod security audit\u001b[0m \u001b[2m· browser-agent\u001b[0m\r\n\r\n  \u001b[2mPod boundary\u001b[0m  \u001b[32m17\u001b[0m/17 with default user\r\n\r\n  \u001b[33m⚠\u001b[0m 6 security notes:\r\n\r\n  \u001b[1mN-03\u001b[0m  \u001b[31m[HIGH]\u001b[0m Direct DNS bypass possible\r\n        \u001b[2mdns.mode is Blacklist — direct IP queries bypass domain filtering.\u001b[0m\r\n        Fix: use dns.mode: Whitelist to block all non-allowed traffic.\r\n\r\n  \u001b[1mS-03\u001b[0m  \u001b[31m[HIGH]\u001b[0m Relaxed seccomp profile\r\n        \u001b[2mseccomp_profile is browser — allows clone3, unshare, and other syscalls blocked by default.\u001b[0m\r\n        Fix: remove security.seccomp_profile or set to default if browser features are not needed.\r\n\r\n  \u001b[1mP-03\u001b[0m  \u001b[33m[MEDIUM]\u001b[0m Nested namespaces possible\r\n        \u001b[2mseccomp_profile is browser — unshare/clone3 allow nested namespace creation.\u001b[0m\r\n        Fix: remove security.seccomp_profile or set to default if browser features are not needed.\r\n\r\n  \u001b[1mI-04\u001b[0m  \u001b[31m[CRITICAL]\u001b[0m X11 display access — keylogging possible\r\n        \u001b[2mdevices.display is true with auto-detection — may use X11, which allows keylogging, screenshots, and input injection.\u001b[0m\r\n        Fix: set display_protocol: wayland for secure display forwarding.\r\n\r\n"]
[57.112071, "o", "  \u001b[1mI-05\u001b[0m  \u001b[31m[HIGH]\u001b[0m Microphone access available\r\n        \u001b[2mdevices.audio is true with auto-detection — may use PulseAudio, which allows unrestricted microphone recording.\u001b[0m\r\n        Fix: set audio_protocol: pipewire for finer-grained audio permissions.\r\n\r\n  \u001b[1mI-06\u001b[0m  \u001b[2m[LOW]\u001b[0m GPU information leakage\r\n        \u001b[2mdevices.gpu is true — nvidia-smi exposes host GPU model to the agent.\u001b[0m\r\n        Fix: set devices.gpu: false if GPU access is not needed.\r\n\r\n  \u001b[32m✓\u001b[0m 4 checks passed (user, memory, cpu, pids)\r\n\r\n"]
[59.115569, "o", "\r\n\u001b[1m\u001b[0;36m━━━ Launch Chrome (command shown — needs display) ━━━\u001b[0m\r\n\r\n"]
