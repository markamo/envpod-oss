[13.146704, "o", "\u001b[2m  ────────────────────────────────────────\u001b[0m\r\n  \u001b[1mPod Created\u001b[0m \u001b[2m·\u001b[0m \u001b[36mclaude-code\u001b[0m  \u001b[2m1.0s\u001b[0m\r\n\u001b[2m  ────────────────────────────────────────\u001b[0m\r\n\r\n  \u001b[2mBackend\u001b[0m  native\r\n  \u001b[2mNetwork\u001b[0m  monitored \u001b[2m·\u001b[0m dns whitelist (16 domains)\r\n  \u001b[2mFS     \u001b[0m  system safe\r\n  \u001b[2mCPU    \u001b[0m  2 cores \u001b[2m·\u001b[0m 4GB\r\n  \u001b[2mBudget \u001b[0m  30m\r\n\r\n\u001b[2m  ────────────────────────────────────────\u001b[0m\r\n"]
